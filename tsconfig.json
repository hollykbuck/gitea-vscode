{
    "compilerOptions": {
        "module": "Node16",
        "target": "ES2022",
        "lib": ["ES2022"],
        "sourceMap": true,
        "rootDir": ".",
        "strict": true,   /* 推荐开启严格模式 */
        "esModuleInterop": true,
        "skipLibCheck": true,
        "outDir": "dist",
        "moduleResolution": "node"
    },
    "include": [
        "extension.ts",
        "features/**/*.ts",
        "src/**/*.ts",
        "test/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        ".vscode-test"
    ]
}
